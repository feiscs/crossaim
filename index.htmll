    <span class="token tag"><span class="token tag"><span class="token punctuation">&lt;</span>style</span><span class="token punctuation">&gt;</span></span>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background-color: #0a0a0a;
            color: #ffffff;
            overflow-x: hidden;
        }
        
        .font-orbitron {
            font-family: 'Orbitron', sans-serif;
        }
        
        .gradient-text {
            background: linear-gradient(135deg, #ff0040 0%, #ff4d00 50%, #ff0040 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .glow-red {
            box-shadow: 0 0 30px rgba(255, 0, 64, 0.5);
        }
        
        .jersey-container {
            perspective: 1000px;
            transition: transform 0.5s ease;
        }
        
        .jersey-container:hover {
            transform: translateY(-10px);
        }
        
        .jersey-card {
            background: linear-gradient(145deg, #1a1a1a 0%, #0d0d0d 100%);
            border: 1px solid #2a2a2a;
            transition: all 0.4s ease;
            position: relative;
            overflow: hidden;
        }
        
        .jersey-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,0,64,0.1) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        
        .jersey-card:hover::before {
            opacity: 1;
        }
        
        .jersey-card:hover {
            border-color: #ff0040;
            box-shadow: 0 20px 40px rgba(255, 0, 64, 0.3);
        }
        
        .player-name {
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.8);
        }
        
        .discord-channel {
            background: rgba(255, 255, 255, 0.05);</code></pre></div></div> <div data-v-71e0e4ea=""></div></div></div> <!----> <!----> <!----></div>  <div data-v-b7eff404="" class="stop-tip-wrapper"><span data-v-b7eff404="" class="stop-tip">Output stopped</span></div> <!---->  <!----> <div data-v-eaf9ef12="" class="okc-cards-container"><!----> <!----> <!----></div> <!----> <!----> <!----> <div data-v-e9c01c9e="" data-v-b7eff404="" class="segment-assistant-actions"><div data-v-e9c01c9e="" class="segment-assistant-actions-content"> <!----> <!----> <!----><div data-v-3827a86b="" data-v-e9c01c9e="" class="icon-button" style="width: 28px; height: 28px;"><svg data-v-3827a86b="" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" role="img" width="16" height="16" viewBox="0 0 1024 1024" name="Copy" class="iconify"><path d="M725.333333 302.933333a166.4 166.4 0 0 1 166.4 166.4v256a166.4 166.4 0 0 1-166.4 166.4h-256A166.4 166.4 0 0 1 302.933333 725.333333v-256A166.4 166.4 0 0 1 469.333333 302.933333h256z m-256 76.8A89.6 89.6 0 0 0 379.733333 469.333333v256c0 49.493333 40.106667 89.6 89.6 89.6h256a89.6 89.6 0 0 0 89.6-89.6v-256A89.6 89.6 0 0 0 725.333333 379.733333h-256z" fill="currentColor"></path><path d="M554.666667 132.266667a166.4 166.4 0 0 1 144.128 83.2 38.4 38.4 0 0 1-66.517334 38.4A89.514667 89.514667 0 0 0 554.666667 209.066667H298.666667A89.6 89.6 0 0 0 209.066667 298.666667v256c0 33.109333 17.92 62.08 44.8 77.653333a38.4 38.4 0 0 1-38.4 66.474667A166.4 166.4 0 0 1 132.266667 554.666667V298.666667A166.4 166.4 0 0 1 298.666667 132.266667h256z" fill="currentColor"></path></svg> <!----></div><!----> <!----><div data-v-3827a86b="" data-v-e9c01c9e="" class="icon-button" style="width: 28px; height: 28px;"><svg data-v-3827a86b="" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" role="img" width="16" height="16" viewBox="0 0 1024 1024" name="Refresh" class="iconify"><path d="M303.104 315.392c114.688-114.688 303.104-114.